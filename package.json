{
  "name": "agentinbox.in",
  "version": "0.1.1",
  "description": "Email verification infrastructure for AI agents and test automation",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentinbox-in/agentinbox-node.git"
  },
  "homepage": "https://agentinbox.in/docs/sdk-node",
  "bugs": {
    "url": "https://github.com/agentinbox-in/agentinbox-node/issues"
  },
  "keywords": [
    "AgentInbox",
    "agentinbox",
    "tempmail",
    "email",
    "verification",
    "otp",
    "mcp",
    "ai",
    "agent",
    "typescript",
    "sdk"
  ],
  "author": "AgentInbox",
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
